# ---------------------------------------------------------------------------
# Frostique — Environment Variables
# ---------------------------------------------------------------------------
# Copy this file to `.env` and fill in the values below.
#   cp .env.example .env
#
# All variables are prefixed with VITE_ so Vite exposes them to the frontend.
# Find these values in your Supabase project: Settings → API
# ---------------------------------------------------------------------------

# Your Supabase project URL (e.g. https://xxxxxxxx.supabase.co)
VITE_SUPABASE_URL=

# Public "anon" / publishable key — safe to expose to the browser.
# In the Supabase dashboard this is the "anon public" key.
# Both variables below use the same anon key value.
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_ANON_KEY=
